### 공통 map item 정규화 (unifiedMapApi.js)

```js
const toMapItem = (type, raw) => ({
  id: `${type}-${raw.idx}`,
  type,                          // 'location' | 'meetup' | 'care'
  latitude: raw.latitude,
  longitude: raw.longitude,
  title: raw.name || raw.title,
  subtitle: {
    location: raw.category || raw.address,
    meetup:   `${raw.meetupDate} · ${raw.currentParticipants}/${raw.maxParticipants}명`,
    care:     `${raw.date} · ${raw.petName || ''}`,
  }[type],
  raw,                           // 인포윈도우 상세용 원본 데이터
});

// 활성 탭 1개만 호출
export const fetchActiveMapItems = async ({ type, lat, lng, radius }) => {
  if (type === 'location') {
    const res = await locationServiceApi.search({
      latitude: lat,
      longitude: lng,
      radius: radius * 1000,
    });
    return (res?.services ?? []).map(r => toMapItem('location', r));
  }

  if (type === 'meetup') {
    const res = await meetupApi.getNearbyMeetups(lat, lng, radius);
    return (res ?? []).map(r => toMapItem('meetup', r));
  }

  if (type === 'care') {
    const res = await careRequestApi.getNearby({ lat, lng, radius });
    return (res ?? []).map(r => toMapItem('care', r));
  }

  return [];
};
```

권장 UI:
- 상단: 탭 헤더 + 반경 필터 + "내 위치로 이동"
- 지도: 도메인별 색/아이콘 구분 (LAYER_CONFIG 기준)
- 인포윈도우: 도메인 핵심 정보 + 상세 이동 링크

